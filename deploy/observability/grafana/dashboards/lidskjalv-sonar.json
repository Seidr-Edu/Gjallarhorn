        {
          "datasource": {
            "type": "postgres",
            "uid": "postgres-observability"
          },
          "editorMode": "code",
          "format": "time_series",
          "rawQuery": true,
          "rawSql": "SELECT $__timeGroupAlias(r.finished_at, '1d'), sr.service_name AS metric,\n  avg(NULLIF((sr.lidskjalv_measures->>'coverage')::double precision, 0)) AS value\nFROM pipeline_obs.service_reports sr\nJOIN pipeline_obs.runs r ON r.run_id = sr.run_id\nWHERE sr.service_name IN ('lidskjalv-original', 'lidskjalv-generated')\n  AND $__timeFilter(r.finished_at)\nGROUP BY 1, 2\nORDER BY 1;",
          "refId": "A"
        }
      ],
      "title": "Coverage Trend",
      "type": "timeseries"
    },
