          "rawQuery": true,
          "rawSql": "SELECT run_id, service_name, lidskjalv_project_key, lidskjalv_quality_gate_status, lidskjalv_ce_task_status, lidskjalv_sonar_task_id\nFROM pipeline_obs.service_reports\nWHERE service_name IN ('lidskjalv-original', 'lidskjalv-generated')\nORDER BY updated_at DESC\nLIMIT 50;",
