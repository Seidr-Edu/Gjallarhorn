      },
      "targets": [
        {
          "datasource": {
            "type": "postgres",
            "uid": "postgres-observability"
          },
          "editorMode": "code",
          "format": "table",
          "rawQuery": true,
          "rawSql": "SELECT coalesce(kvasir_behavioral_verdict_reason, '<none>') AS reason, count(*) AS failures\nFROM pipeline_obs.service_reports\nWHERE service_name = 'kvasir' AND coalesce(kvasir_behavioral_verdict, '') <> 'pass'\nGROUP BY reason\nORDER BY failures DESC\nLIMIT 20;",
          "refId": "A"
        }
      ],
      "title": "Top Behavioral Failure Reasons",
      "type": "table"
    },
