          "rawQuery": true,
          "rawSql": "SELECT coalesce(kvasir_behavioral_verdict, '<none>') AS verdict, count(*) AS value\nFROM pipeline_obs.service_reports\nWHERE service_name = 'kvasir'\nGROUP BY verdict\nORDER BY value DESC;",
