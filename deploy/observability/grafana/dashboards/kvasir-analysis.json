          "editorMode": "code",
          "format": "table",
          "rawQuery": true,
          "rawSql": "SELECT run_id,\n  coalesce(kvasir_write_scope_violation_count, 0) AS write_scope_violations,\n  kvasir_behavioral_verdict,\n  (kvasir_retention_metrics->>'retention_ratio') AS retention_ratio\nFROM pipeline_obs.service_reports\nWHERE service_name = 'kvasir'\nORDER BY updated_at DESC\nLIMIT 50;",
          "refId": "A"
        }
      ],
      "title": "Write-scope and Retention Signals",
