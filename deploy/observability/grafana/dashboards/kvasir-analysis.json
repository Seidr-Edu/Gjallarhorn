          "datasource": {
            "type": "postgres",
            "uid": "postgres-observability"
          },
          "editorMode": "code",
          "format": "time_series",
          "rawQuery": true,
          "rawSql": "SELECT $__timeGroupAlias(r.finished_at, '1d'), 'retention_ratio' AS metric,\n  avg(NULLIF((sr.kvasir_retention_metrics->>'retention_ratio')::double precision, 0)) AS value\nFROM pipeline_obs.service_reports sr\nJOIN pipeline_obs.runs r ON r.run_id = sr.run_id\nWHERE sr.service_name = 'kvasir' AND $__timeFilter(r.finished_at)\nGROUP BY 1\nORDER BY 1;",
          "refId": "A"
        }
      ],
      "title": "Retention Ratio Trend",
      "type": "timeseries"
    },
