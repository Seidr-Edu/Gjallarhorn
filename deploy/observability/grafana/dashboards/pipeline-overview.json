          "editorMode": "code",
          "format": "table",
          "rawQuery": true,
          "rawSql": "SELECT service_name, coalesce(reason, '<none>') AS reason, count(*) AS failures\nFROM pipeline_obs.service_reports\nWHERE status IN ('failed', 'error')\nGROUP BY service_name, coalesce(reason, '<none>')\nORDER BY failures DESC, service_name ASC\nLIMIT 25;",
          "refId": "A"
        }
      ],
      "title": "Failure Counts by Service and Reason",
      "type": "table"
