          "editorMode": "code",
          "format": "time_series",
          "rawQuery": true,
          "rawSql": "SELECT $__timeGroupAlias(finished_at, '1h'), status AS metric, count(*)::double precision AS value\nFROM pipeline_obs.runs\nWHERE $__timeFilter(finished_at)\nGROUP BY 1, 2\nORDER BY 1;",
          "refId": "A"
        }
      ],
      "title": "Runs by Status Over Time",
      "type": "timeseries"
