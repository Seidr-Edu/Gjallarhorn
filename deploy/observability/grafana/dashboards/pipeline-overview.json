      },
      "targets": [
        {
          "datasource": {
            "type": "postgres",
            "uid": "postgres-observability"
          },
          "editorMode": "code",
          "format": "table",
          "rawQuery": true,
          "rawSql": "SELECT step_name,\n  round((percentile_cont(0.5) WITHIN GROUP (ORDER BY EXTRACT(EPOCH FROM (finished_at - started_at))))::numeric, 2) AS median_seconds,\n  round((percentile_cont(0.95) WITHIN GROUP (ORDER BY EXTRACT(EPOCH FROM (finished_at - started_at))))::numeric, 2) AS p95_seconds,\n  count(*) AS samples\nFROM pipeline_obs.run_steps\nWHERE started_at IS NOT NULL AND finished_at IS NOT NULL\nGROUP BY step_name\nORDER BY step_name;",
          "refId": "A"
        }
      ],
      "title": "Median and P95 Step Duration",
      "type": "table"
    },
